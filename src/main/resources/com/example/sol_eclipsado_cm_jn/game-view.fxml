<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.sol_eclipsado_cm_jn.controller.GameController"
      alignment="CENTER"
      spacing="18"
      prefWidth="560"
      prefHeight="360">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <children>
        <Label text="Zona de juego - Sol Eclipsado"
               style="-fx-font-size: 24px; -fx-font-weight: bold;" />

        <Label fx:id="gameStatusLabel"
               text="Preparando el juego..."
               wrapText="true"
               style="-fx-font-size: 14px;" />

        <Label fx:id="wordLengthLabel"
               text=""
               wrapText="true"
               style="-fx-font-size: 14px;" />

        <Label fx:id="remainingAttemptsLabel"
               text=""
               wrapText="true"
               style="-fx-font-size: 14px; -fx-font-weight: bold;" />

        <GridPane fx:id="lettersGridPane"
                  hgap="8"
                  vgap="8"
                  style="-fx-alignment: center;" />
    </children>
</VBox>